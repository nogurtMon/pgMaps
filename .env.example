# ─── Required (Vercel / Local only) ──────────────────────────────────────────

# Postgres connection string for the app's own storage (saved connections, views).
# Not needed for Docker — a database is bundled automatically.
POSTGRES_URL=postgres://user:password@host:5432/dbname

# 64-character hex key used to encrypt database connection strings at rest.
# Not needed for Docker or local dev — auto-generated on first run.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DSN_ENCRYPTION_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Password to access the app at /map.
# If unset, no login is required.
# APP_PASSWORD=

# If set, / shows the marketing landing page. Otherwise / redirects to /map.
# SHOW_LANDING_PAGE=true

# Docker only — default is 3000.
# PORT=3000
