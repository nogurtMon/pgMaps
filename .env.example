# ─── Required ────────────────────────────────────────────────────────────────

# Postgres connection string for the app's own storage (saved connections, views).
# The app creates its tables automatically on first run.
POSTGRES_URL=postgres://user:password@host:5432/dbname

# 64-character hex key used to encrypt database connection strings at rest.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DSN_ENCRYPTION_KEY=

# ─── Recommended ─────────────────────────────────────────────────────────────

# Password to access the app at /map (read/write access to your databases).
# If unset, no login is required — anyone with the URL can use the app.
# Share links at /share/[id] remain public regardless of this setting.
APP_PASSWORD=yourpassword

# ─── Optional ────────────────────────────────────────────────────────────────

# If set, the root URL (/) shows the marketing landing page.
# Otherwise / redirects to /map.
# SHOW_LANDING_PAGE=true

# Docker only — default is 3000.
# PORT=3000
