# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string used as the app's storage database (saved
# connections, maps, basemap configs). Point it at any PostgreSQL instance.
POSTGRES_URL=

# Password protecting the app. Public share links (/share/[id]) remain
# accessible regardless.
APP_PASSWORD=

# 32-byte hex key used to encrypt saved connection strings at rest.
# Generate with: openssl rand -hex 32
DSN_ENCRYPTION_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# If set, / shows the marketing landing page. Otherwise / redirects to /maps.
# SHOW_LANDING_PAGE=true

# Default is 3000.
# PORT=3000
